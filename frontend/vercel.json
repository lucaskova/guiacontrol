{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:web",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://guiacontrol.onrender.com/api/:path*"
    },
    { "source": "/((?!_expo|assets|api|.*\\..*).*)", "destination": "/index.html" }
  ]
}
