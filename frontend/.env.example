# URL pública do backend (Render)
EXPO_PUBLIC_BACKEND_URL=https://api.seudominio.com

# URL pública do app web (Vercel) — usada nos links do portal do cliente
EXPO_PUBLIC_WEB_APP_URL=https://app.seudominio.com

# Mostrar botão "Entrar com Google" (Emergent). Local: false.
EXPO_PUBLIC_ENABLE_GOOGLE_AUTH=false

EXPO_USE_FAST_RESOLVER=1
