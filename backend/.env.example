# ===== MongoDB =====
# Use MongoDB Atlas em produção. Cole a connection string aqui.
MONGO_URL=mongodb+srv://USUARIO:SENHA@cluster.mongodb.net/?appName=GuiaControl
DB_NAME=guiacontrol

# ===== Auth / Cookie =====
# Em produção (HTTPS, frontend em outro domínio): true
# Em desenvolvimento (HTTP localhost): false
AUTH_COOKIE_SECURE=true

# ===== API Brasil (WhatsApp) =====
APIBRASIL_BEARER_TOKEN=
APIBRASIL_DEVICE_TOKEN=
WHATSAPP_PROVIDER=apibrasil

# ===== URL pública do portal do cliente =====
# Em produção: o domínio do app (Vercel), ex.: https://app.guiacontrol.com.br
PUBLIC_CLIENT_BASE_URL=https://app.seudominio.com

# ===== Admin (whitelist) =====
# E-mails autorizados a acessar /admin (separados por vírgula)
ADMIN_EMAILS=seu-email@exemplo.com

# ===== CORS =====
# Domínios autorizados (separados por vírgula). Use o domínio real do seu app na Vercel.
CORS_ALLOW_ORIGINS=https://app.seudominio.com,https://landing.seudominio.com
