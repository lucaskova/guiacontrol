# Copie para .env (ou mescle com o seu) quando usar MongoDB Atlas (gratis).
# 1) https://www.mongodb.com/cloud/atlas → criar cluster → Connect → Drivers
# 2) Network Access: adicione seu IP (ou 0.0.0.0/0 so para teste)
# 3) Cole a URI abaixo (substitua <password> e remova <> do host)

# Senha com @, #, etc.: use o botao Copy do Atlas (ja codifica) ou %40 no lugar de @
# NAO use < > na URI (eram placeholder do Atlas, nao fazem parte da senha)
MONGO_URL="mongodb+srv://USUARIO:SENHA@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0"
DB_NAME="test_database"
AUTH_COOKIE_SECURE=false
