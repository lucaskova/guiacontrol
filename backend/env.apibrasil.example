# Copie estas linhas para backend/.env (junto com MONGO_URL).
# Painel: https://app.apibrasil.io → credenciais da conta (Bearer + Device).
# Cada contador conecta o WhatsApp DELE pelo QR no app (Notificacoes > Conectar).

APIBRASIL_BEARER_TOKEN=seu_bearer_aqui
APIBRASIL_DEVICE_TOKEN=seu_device_token_aqui
# Opcional:
# APIBRASIL_GATEWAY_URL=https://gateway.apibrasil.io
# APIBRASIL_SECRET_KEY=
# APIBRASIL_PUBLIC_TOKEN=
